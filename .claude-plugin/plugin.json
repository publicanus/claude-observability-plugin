{
  "name": "langfuse",
  "description": "The Langfuse x Claude Code Observability Plugin",
  "version": "2.0.2",
  "author": {
    "name": "Langfuse"
  },
  "repository": "https://github.com/langfuse/Claude-Observability-Plugin",
  "license": "MIT",
  "homepage": "https://langfuse.com/integrations/other/claude-code",
  "userConfig": {
    "LANGFUSE_SECRET_KEY": {
      "type": "string",
      "title": "Langfuse Secret Key",
      "description": "Your Langfuse project secret key (sk-lf-...)",
      "sensitive": true,
      "required": true
    },
    "LANGFUSE_PUBLIC_KEY": {
      "type": "string",
      "title": "Langfuse Public Key",
      "description": "Your Langfuse project public key (pk-lf-...)",
      "required": true
    },
    "LANGFUSE_BASE_URL": {
      "type": "string",
      "title": "Langfuse Base URL",
      "description": "Langfuse host. Use https://us.cloud.langfuse.com for US, https://cloud.langfuse.com for EU, or your self-hosted URL.",
      "default": "https://us.cloud.langfuse.com"
    },
    "CC_LANGFUSE_DEBUG": {
      "type": "boolean",
      "title": "Debug logging",
      "description": "Write verbose logs to ~/.claude/state/langfuse_hook.log",
      "default": false
    }
  }
}
